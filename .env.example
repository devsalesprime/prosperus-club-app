# ─── FRONTEND (Vite bundle — dados públicos apenas) ──────────────
# Obtido em: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://[PROJECT_REF].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ[ANON_KEY]

# Obtido em: npx web-push generate-vapid-keys (chave PÚBLICA)
VITE_VAPID_PUBLIC_KEY=BFS8[VAPID_PUBLIC_KEY]

# URL pública da galeria de fotos
VITE_GALLERY_URL=https://photos.app.goo.gl/[ALBUM_ID]

# ─── SERVER-SIDE LOCAL (nunca commitar com valores reais) ─────────
# Obtido em: Supabase Dashboard → Settings → API → Service Role Key
# Usado apenas localmente para seed scripts
SUPABASE_SERVICE_ROLE_KEY=eyJ[SERVICE_ROLE_KEY]

# ─── SENTRY (observabilidade — ADR-014) ──────────────────────────
# DSN público do projeto Sentry. Obtido em: sentry.io → Project → Settings
# → Client Keys (DSN). Pode ficar no bundle: é por design público.
# Em DEV ou sem este valor, o Sentry SDK NÃO inicializa (zero overhead).
VITE_SENTRY_DSN=https://[PUBLIC_KEY]@[ORG].ingest.sentry.io/[PROJECT_ID]

# Org slug e Project slug — usados pelo @sentry/vite-plugin para upload
# de source maps. Obtidos da URL do Dashboard Sentry (org-slug/project-slug)
VITE_SENTRY_ORG=prosperus-club
VITE_SENTRY_PROJECT=prosperus-club-app

# Token de auth do Sentry, SÓ usado em build (CI ou build local de deploy).
# NUNCA vai pro bundle. Sem este, o plugin desativa gracefully e source maps
# não são uploadadas — produção fica funcional mas erros vêm minificados.
# Obtido em: sentry.io → Settings → Account → API → Auth Tokens
# Scopes necessários: project:read, project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_[AUTH_TOKEN]

# ─── SUPABASE SECRETS (configurar no Dashboard, NÃO aqui) ────────
# Supabase Dashboard → Settings → Edge Functions → Secrets
#
# HUBSPOT_ACCESS_TOKEN=     ← HubSpot → Private Apps → Access Token
# HUBSPOT_CLIENT_SECRET=    ← HubSpot → Private Apps → Client Secret
# VAPID_PRIVATE_KEY=        ← npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=         ← mesma public key do VITE_VAPID_PUBLIC_KEY
# APP_URL=                  ← https://app.prosperusclub.com.br
# SUPABASE_URL=             ← automático nas Edge Functions
# SUPABASE_SERVICE_ROLE_KEY= ← automático nas Edge Functions
